<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.MonarchPOS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/monarch_gold</item>
        <item name="colorPrimaryVariant">@color/monarch_dark_gold</item>
        <item name="colorOnPrimary">@color/black</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/monarch_dark_gold</item>
        <item name="colorSecondaryVariant">@color/monarch_gold</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor" >@color/black</item>
        <item name="android:windowFullscreen">true</item>

        <!-- Customize your theme here. -->
    </style>

    <style name="button">
        <item name="android:textColor">@color/selector_btn_text</item>
        <item name="android:gravity">center_horizontal|center_vertical</item>
        <item name="android:background">@drawable/selector_btn</item>
    </style>

    <style name="button_secondary_default" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/button_secondary_default</item>
        <item name="android:background">@drawable/btn_secondary_default</item>
    </style>

    <style name="button_default" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/black</item>
        <item name="android:background">@drawable/btn_default</item>
    </style>

    <style name="KeyboardDigitStyle">
        <item name="android:textColor">@color/text_keyboard</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:gravity">center_horizontal|center_vertical</item>
    </style>

    <style name="Theme.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/selector_textinputlayout_border</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="hintTextColor">@color/edit_border</item>
        <item name="boxCornerRadiusBottomEnd">6dp</item>
        <item name="boxCornerRadiusBottomStart">6dp</item>
        <item name="boxCornerRadiusTopEnd">6dp</item>
        <item name="boxCornerRadiusTopStart">6dp</item>
    </style>

    <style name="AmountStyle">
        <item name="android:textColor">@color/text_amount</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_centerHorizontal">true</item>
        <item name="android:layout_alignParentTop">true</item>
        <item name="android:gravity">center_horizontal|center_vertical</item>
    </style>
</resources>